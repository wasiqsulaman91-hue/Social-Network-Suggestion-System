{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build SocialNetworkSuggestionSystem",
            "type": "shell",
            "command": "C:\\MinGW\\bin\\g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "Main.cpp",
                "App_Code/NetworkGraph.cpp",
                "App_Code/Recommendation_System.cpp",
                "App_Code/CustomQueue.cpp",
                "-I",
                "C:\\SFML\\include",
                "-L",
                "C:\\SFML\\lib",
                "-lsfml-graphics",
                "-lsfml-window",
                "-lsfml-system",
                "-o",
                "${workspaceFolder}\\bin\\SNA_Run.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Build the full project using MinGW g++.exe"
        },
